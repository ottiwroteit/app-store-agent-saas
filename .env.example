# App Store Connect API
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_PRIVATE_KEY_PATH=
ASC_VENDOR_NUMBER=

# In-App Purchase / App Store Server API
IAP_KEY_ID=
IAP_ISSUER_ID=
IAP_PRIVATE_KEY_PATH=

# Apple Search Ads Campaign Management API v5
# Apple Ads uses OAuth client credentials. Fill these from Apple Ads API settings.
APPLE_ADS_CLIENT_ID=
APPLE_ADS_TEAM_ID=
APPLE_ADS_KEY_ID=
APPLE_ADS_PRIVATE_KEY_PATH=
APPLE_ADS_ORG_ID=

# Optional
PORT=4177

# Rank Rescue ASO SaaS
ASO_SAAS_PUBLIC_URL=
ASO_CREDENTIAL_VAULT_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ASO_RESCUE_PRICE_ID=
STRIPE_ASO_GROWTH_PRICE_ID=
STRIPE_ASO_STUDIO_PRICE_ID=

# Rank Rescue production storage
# Optional. Without these, the console uses data/aso-saas-workspaces.json and data/aso-saas-notification-outbox.json.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ASO_SUPABASE_WORKSPACES_TABLE=aso_saas_workspaces
ASO_SUPABASE_NOTIFICATIONS_TABLE=aso_saas_notifications
ASO_MONITOR_ADMIN_TOKEN=

# Rank Rescue digest delivery
RESEND_API_KEY=
ASO_ALERT_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
